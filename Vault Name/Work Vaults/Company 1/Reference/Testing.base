views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "Work Vaults/Company 1/Department 1/Testing"
        - Status != "Done"
        - Project == "Project 1"
        - Platform == "Platform 1"
        - Company == "Company 1"
        - Department == "Department 1"
    order:
      - file.name
      - Status
      - Project
      - Parent
      - Department
      - Company
    columnSize:
      file.name: 158
