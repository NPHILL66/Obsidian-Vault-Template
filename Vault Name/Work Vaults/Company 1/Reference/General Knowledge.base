views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "Work Vaults/Company 1/General Knowledge"
        - Parent == "Work"
        - Company == "Company 1"
    order:
      - file.name
      - Company
      - Department
      - Parent
      - Platform
      - Project
    columnSize:
      file.name: 245
