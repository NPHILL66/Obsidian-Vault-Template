views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "Work Vaults/Company 1/Systems/_Homepages"
        - Parent == "Work"
        - Company == "Company 1"
    order:
      - file.name
      - Parent
      - Company
      - Project
      - Platform
      - Kind
    columnSize:
      file.name: 167
      note.Parent: 84
      note.Company: 108
      note.Project: 91
      note.Platform: 104
