views:
  - type: cards
    name: Table
    filters:
      and:
        - file.folder == "Projects and Tasks"
        - Parent == "Personal"
        - Status != "Done"
        - note["Time Start"] <= "2026-05-01T12:00:00"
    order:
      - file.name
      - Time Start
    sort:
      - property: Time Start
        direction: ASC
    cardSize: 160
