views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "Rookery/Work Vaults/Meijer/Learning and Educational Programs/Projects"
    order:
      - file.name
      - Company
      - Completed
      - Date Due
      - Department
      - Dependent
      - Notes
      - Parent
      - Platform
      - Project
      - Status
    sort:
      - property: Status
        direction: DESC
    columnSize:
      file.name: 255
